#!/usr/bin/env bash

set -u

SCRIPT_NAME=$(basename "$0")
print_help() {
    echo "Usage:"
    echo "$SCRIPT_NAME re [mode] [ag_args]"
    echo "re - regexp for ag"
    echo "mode: v|d default:v"
}

if [ $# -lt 1 ]; then
    print_help
    exit 1
fi

re=$1
shift
mode=${1:-v}
shift

view_cmd="history | ag $@ '$re'"

if [ "$mode" = 'v' ]; then
    echo " $view_cmd"
    exit $?
fi

if [ "$mode" = 'd' ]; then
    echo " echo '';$view_cmd;echo '';for _i in \`$view_cmd | awk '{print \$1;}' | tr '*' ' ' | sort -rn\`; do history -d \$_i || echo \"Error: history -d \$_i\"; done;unset _i;$view_cmd && echo 'Check history' || echo 'Removed - Ok'"
    exit $?
fi

echo "Check mode: $mode"
print_help
exit 1
